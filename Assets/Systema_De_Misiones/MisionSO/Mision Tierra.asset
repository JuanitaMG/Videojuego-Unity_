  m_Name: Mision Tierra
  m_EditorClassIdentifier: Assembly-CSharp::MisionSO
  misionId: MISION_TIERRA_01
  misionName: Roca Viva
  description: "Descripci\xF3n:\r\nBajo la tierra se forman minerales vivos llamados
    \u201CRoca Viva\u201D.\r\nEl guardi\xE1n necesita algunas para reforzar las ra\xEDces
    del bosque.\r\n"
  zone: 3
  recompensaGemas: 1
  itemIDObjetivo: ROCA_VIVA
  cantidadObjetivo: 5
  puntoDeEntrega: {fileID: 2676405798547930095, guid: 4b5b08dfd84e3c342b10a4e2ed977d48, type: 3}
  dialogoCuandoAceptaMision: "\"La tierra te llama.\r\nRecolecta 3 Rocas Vivas.\r\nSe
    forman cerca de los \xE1rboles gigantes.\"\r\n"
  dialogoCuandoEstaActiva: "Di\xE1logo cuando ya est\xE1 activa:\r\n\"La tierra espera
    tus pasos\u2026 sigue buscando.\"\r\n"
  dialogoCuandoCompletada: "Di\xE1logo cuando se completa:\r\n\"Excelente.\r\nToma
    esta Gema de Tierra, representante de la fuerza del mundo.\"\r\n"
