  puntoDeEntrega: {fileID: 498253721416304272, guid: f6ab88624626d1249bd73bcb4a1c7d59, type: 3}
  dialogoCuandoAceptaMision: "\"\xBFPuedes sentirlo? La tierra arde.\nRecolecta 4
    N\xFAcleos \xCDgneos.\nProvienen de criaturas que arden en la lava.\nCon ellos
    podremos evitar una erupci\xF3n.\""
  dialogoCuandoEstaActiva: "\"El fuego no espera.\nNecesito esos n\xFAcleos antes
    de que todo colapse.\""
  dialogoCuandoCompletada: "\"Has domado el fuego.\nToma esta Gema de Fuego y sigue
    adelante, h\xE9roe.\""
