  puntoDeEntrega: {fileID: 958745142335686053, guid: 95aa05ec0ea0a884ab92946b57d2c7b4, type: 3}
  dialogoCuandoAceptaMision: "\"Escucha al viento viajero.\r\nRecolecta 7 Esencias
    del Aire Antiguo.\r\nEst\xE1n suspendidas entre los pilares celestes.\"\r\n"
  dialogoCuandoEstaActiva: "\"El viento murmura\u2026 a\xFAn te faltan esencias.\""
  dialogoCuandoCompletada: "\"El viento te reconoce.\r\nAcepta esta Gema de Viento,
    s\xEDmbolo de armon\xEDa.\"\r\n"
